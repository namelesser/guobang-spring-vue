{
  "name": "guobang-transport-frontend",
  "version": "1.0.0",
  "description": "国邦运输管理系统前端",
  "keywords": [
    "TypeScript",
    "UnoCSS",
    "Vite8",
    "naive-ui",
    "transport"
  ],
  "license": "MIT",
  "type": "module",
  "scripts": {
    "build": "vite build --mode prod",
    "build:test": "vite build --mode test",
    "dev": "vite --mode test",
    "dev:prod": "vite --mode prod",
    "fmt": "oxfmt",
    "lint": "oxlint --fix && eslint --fix .",
    "prepare": "simple-git-hooks",
    "preview": "vite preview",
    "typecheck": "vue-tsc --noEmit --skipLibCheck"
  },
  "dependencies": {
    "@iconify/vue": "5.0.1",
    "@sa/axios": "workspace:*",
    "@sa/utils": "workspace:*",
    "@vueuse/core": "14.3.0",
    "dayjs": "1.11.20",
    "json5": "2.2.3",
    "naive-ui": "2.44.1",
    "pinia": "3.0.4",
    "tailwind-merge": "3.6.0",
    "vue": "3.5.34",
    "vue-i18n": "11.4.2",
    "vue-router": "5.0.7"
  },
  "devDependencies": {
    "@iconify/json": "2.2.472",
    "@sa/scripts": "workspace:*",
    "@sa/uno-preset": "workspace:*",
    "@soybeanjs/eslint-config-vue": "^0.0.2",
    "@types/node": "25.7.0",
    "@vitejs/plugin-vue": "6.0.6",
    "@vitejs/plugin-vue-jsx": "5.1.5",
    "consola": "3.4.2",
    "eslint": "10.3.0",
    "kolorist": "1.8.0",
    "oxfmt": "^0.49.0",
    "oxlint": "^1.64.0",
    "sass": "1.99.0",
    "simple-git-hooks": "2.13.1",
    "tsx": "4.21.0",
    "typescript": "6.0.3",
    "unocss": "^66.6.8",
    "unplugin-icons": "23.0.1",
    "unplugin-vue-components": "32.0.0",
    "vite": "8.0.12",
    "vue-tsc": "3.2.8"
  },
  "simple-git-hooks": {
    "commit-msg": "pnpm sa git-commit-verify",
    "pre-commit": "pnpm typecheck && pnpm lint && pnpm fmt && git diff --exit-code"
  },
  "engines": {
    "node": ">=20.19.0",
    "pnpm": ">=10.5.0"
  }
}
